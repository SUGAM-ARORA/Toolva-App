# Server Configuration
PORT=8080
ENV=development

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_password
DB_NAME=toolva_db

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT Configuration
JWT_SECRET=your_jwt_secret_key
JWT_EXPIRATION=24h

# API Configuration
API_VERSION=v1
API_PREFIX=/api

# CORS Configuration
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:19006

# File Upload Configuration
MAX_FILE_SIZE=5242880 # 5MB
UPLOAD_DIR=uploads

# Rate Limiting
RATE_LIMIT=100
RATE_LIMIT_WINDOW=1h 